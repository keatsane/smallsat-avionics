# static analysis for the host C++ flight software (fsw), run by the CI flight-sw job
# (no local recipe - windows/mingw needs header-path injection that isn't worth carrying).
# scoped to fsw's own sources - the vendored doctest and ETL aren't the target.
Checks: >
  -*,
  bugprone-*,
  performance-*,
  portability-*,
  modernize-use-nullptr,
  modernize-use-override,
  modernize-use-equals-default,
  readability-braces-around-statements,
  readability-misleading-indentation,
  readability-redundant-control-flow
WarningsAsErrors: ''
HeaderFilterRegex: '.*/fsw/(include|src|platform|sil)/.*'
FormatStyle: file
