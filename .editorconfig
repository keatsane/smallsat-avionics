# editorconfig.org
root = true

# defaults for everything
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# c / c++
[*.{c,h,cpp,hpp}]
indent_size = 4
max_line_length = 100

# python - pep 8
[*.py]
indent_size = 4
max_line_length = 100

# cmake / data / config
[{CMakeLists.txt,*.cmake,*.yaml,*.yml,*.json}]
indent_size = 2

# markdown - keep trailing spaces for hard breaks
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# makefiles need real tabs
[Makefile]
indent_style = tab
