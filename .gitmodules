[submodule "vendor/cmsis-core"]
	path = vendor/cmsis-core
	url = https://github.com/STMicroelectronics/cmsis-core.git
[submodule "vendor/cmsis-device-f4"]
	path = vendor/cmsis-device-f4
	url = https://github.com/STMicroelectronics/cmsis-device-f4.git
[submodule "vendor/FreeRTOS-Kernel"]
	path = vendor/FreeRTOS-Kernel
	url = https://github.com/FreeRTOS/FreeRTOS-Kernel.git
[submodule "vendor/etl"]
	path = vendor/etl
	url = https://github.com/ETLCPP/etl.git
